{
  "name": "@pos/api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend NestJS modular monolith para SaaS POS multi-tenant",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n tsc,api -c green,cyan \"tsc -w --preserveWatchOutput\" \"node --watch dist/main.js\"",
    "build": "tsc -p tsconfig.json && node -e \"import('fs').then(fs => fs.cpSync('prisma/tenants', 'dist/prisma/tenants', { recursive: true }))\"",
    "start": "node dist/main.js",
    "lint": "biome check src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "clean": "rimraf dist .turbo coverage"
  },
  "dependencies": {
    "@fastify/multipart": "^9.0.1",
    "@fastify/static": "^9.3.0",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.0.1",
    "@nestjs/swagger": "^11.0.3",
    "@nestjs/throttler": "^6.2.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.56.0",
    "@prisma/adapter-pg": "^6.0.0",
    "@prisma/client": "^6.0.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.34.0",
    "bwip-js": "^4.5.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.5.1",
    "fastify": "^5.1.0",
    "fastify-static": "^4.7.0",
    "ioredis": "^5.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^3.1.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "stripe": "^17.3.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.9.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.5",
    "@vitest/coverage-v8": "^2.1.6",
    "concurrently": "^10.0.3",
    "prisma": "^6.0.0",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.6"
  }
}

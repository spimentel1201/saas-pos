# Base de datos principal (tablas compartidas: tenants, users, subscriptions, tenants_users)
# El docker-compose.yml expone Postgres en 15432 para evitar choque con un Postgres nativo del host.
DATABASE_URL=postgresql://postgres:postgres@localhost:15432/pos_saas?schema=public
SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:15432/pos_saas_shadow

# Redis (BullMQ + cache)
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Stripe (suscripciones SaaS)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# Cloudinary (imagenes producto + QR/barcode)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=pos-products

# App
APP_BASE_URL=http://localhost:3001
API_PORT=3000
TENANT_BASE_DOMAIN=localhost
POS_OFFLINE_TTL_HOURS=4

# Observabilidad
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Email (mailhog en dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=no-reply@posapp.local
